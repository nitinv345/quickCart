{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User full name" },
        "email": { "type": "string", "description": "User email address" },
        "phone": { "type": "string", "description": "User phone number" },
        "role": { "type": "string", "enum": ["user", "admin", "delivery"], "description": "User role" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Grocery product details",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Price" },
        "discountPrice": { "type": "number", "description": "Discounted price" },
        "category": { "type": "string", "description": "Category ID" },
        "stock": { "type": "number", "description": "Stock quantity" },
        "image": { "type": "string", "description": "Image URL" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "icon": { "type": "string", "description": "Icon URL" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "products": { "type": "array", "description": "List of products" },
        "totalPrice": { "type": "number", "description": "Total price" },
        "status": { "type": "string", "enum": ["placed", "packed", "out_for_delivery", "delivered"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order creation timestamp" }
      },
      "required": ["userId", "products", "totalPrice", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Product catalog"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "Category" },
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Customer orders"
    }
  }
}
